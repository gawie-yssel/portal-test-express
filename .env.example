# Copy to .env for local development (.env is gitignored).

PORT=3000

# --- Postgres ---
# Either set a full connection string...
DATABASE_URL=
# ...or the discrete parts (used when DATABASE_URL is empty):
PGHOST=
PGPORT=5432
PGUSER=
PGPASSWORD=
PGDATABASE=
# Set to "true" for managed/SSL Postgres (uses rejectUnauthorized: false).
PGSSL=false

# --- S3 ---
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
# For S3-compatible servers (MinIO, LocalStack, etc.). Leave empty for real AWS.
# When set, the client uses this URL and path-style addressing.
S3_ENDPOINT=
