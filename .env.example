# Copy to .env for local development (.env is gitignored).

PORT=3000

# --- Postgres ---
# Either set a full connection string...
DATABASE_URL=
# ...or the discrete parts (used when DATABASE_URL is empty):
PGHOST=
PGPORT=5432
PGUSER=
PGPASSWORD=
PGDATABASE=
# Set to "true" for managed/SSL Postgres (uses rejectUnauthorized: false).
PGSSL=false

# --- S3 ---
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
# For S3-compatible servers (MinIO, LocalStack, etc.). Leave empty for real AWS.
# When set, the client uses this URL and path-style addressing.
S3_ENDPOINT=

# --- Observability ---
# Console log verbosity: error | warn | info | debug
LOG_LEVEL=info
# Set to "true" to log truncated SQL text (never param values) and capture SQL
# params on Postgres telemetry spans. Off by default since SQL is user input.
LOG_SQL=false

# OpenTelemetry (traces + metrics over OTLP). Any standard OTEL_* var is honored.
OTEL_SERVICE_NAME=portal-test-express
# OTLP collector endpoint, e.g. http://localhost:4318. Leave empty if no collector.
OTEL_EXPORTER_OTLP_ENDPOINT=
# Set to "true" to disable OpenTelemetry entirely.
OTEL_SDK_DISABLED=false
